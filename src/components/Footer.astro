---
// z-10 so this still sits above the homepage's fixed particle canvas
// (which paints at z-index: 0) — harmless on inner pages that have no canvas.
const year = new Date().getFullYear();

const links = [
	{ href: '/work', label: 'Work' },
	{ href: '/experiments', label: 'Experiments' },
	{ href: '/blog', label: 'Blog' },
	{ href: '/studio', label: 'Studio' },
	{ href: '/contact', label: 'Contact' },
];
---

<footer class="relative z-10 border-t border-white/5 px-6 py-16">
	<div class="mx-auto flex max-w-6xl flex-col gap-8 sm:flex-row sm:items-end sm:justify-between">
		<div>
			<a
				href="/"
				class="text-small tracking-wide text-neutral-300 transition-colors hover:text-neutral-50"
			>
				Anyrvaan
			</a>
			<p class="mt-3 max-w-xs text-small text-neutral-600">Design × Technology × Experiences.</p>
		</div>
		<nav>
			<ul class="flex flex-wrap gap-x-6 gap-y-2">
				{
					links.map((link) => (
						<li>
							<a
								href={link.href}
								class="text-small text-neutral-400 transition-colors hover:text-neutral-50"
							>
								{link.label}
							</a>
						</li>
					))
				}
			</ul>
		</nav>
	</div>
	<p class="mx-auto mt-12 max-w-6xl text-small text-neutral-700">© {year} Anyrvaan. All rights reserved.</p>
</footer>
