---
// Interaction Lab card. The effect lives in the typography: hovering the card
// hides the real title text and a canvas replica of it (same computed font)
// performs the experiment's own mechanic — letters fold, melt, scatter, sag,
// split into RGB — per src/scripts/experiment-previews.ts. The same renderer
// drives the fullscreen page, so the hover is a true miniature of it.
// `transition:name` lets the click-through grow out of this exact card.
interface Props {
	slug: string;
	order: number;
	codename: string;
	classification: string;
	description: string;
	tags?: string[];
}

const { slug, order, codename, classification, description, tags = [] } = Astro.props;
---

<a
	href={`/experiments/${slug}`}
	class="frost-card frost-card--link experiment-card group relative block overflow-hidden rounded-2xl p-8"
	transition:name={`experiment-${slug}`}
>
	<div class="relative z-10">
		<div class="flex items-start justify-between gap-4">
			<p class="text-eyebrow uppercase text-neutral-400">{classification}</p>
			<p class="shrink-0 text-small tabular-nums text-neutral-600">{String(order).padStart(2, '0')}</p>
		</div>
		<h3 class="mt-5 text-h3 text-neutral-50">
			<span class="title-fx">
				<span class="title-fx__text">{codename}</span>
				<canvas class="title-fx__canvas" aria-hidden="true" data-slug={slug} data-codename={codename}
				></canvas>
			</span>
		</h3>
		<p class="mt-4 text-body text-neutral-400">{description}</p>
		{
			tags.length > 0 && (
				<ul class="mt-6 flex flex-wrap gap-x-4 gap-y-1">
					{tags.map((t) => (
						<li class="text-small text-neutral-500 transition-colors group-hover:text-neutral-400" data-bloom>
							{t}
						</li>
					))}
				</ul>
			)
		}
	</div>
</a>

<style>
	.title-fx {
		position: relative;
		display: inline-block;
	}
	/* Insets/size are set by mountExperimentPreview from the computed font
	   size, so effects get room to overflow the glyph box in every direction. */
	.title-fx__canvas {
		position: absolute;
		pointer-events: none;
	}
</style>

<script>
	import { mountExperimentPreview } from '../scripts/experiment-previews';

	function initExperimentPreviews() {
		document
			.querySelectorAll<HTMLAnchorElement>('.experiment-card:not([data-preview-init])')
			.forEach((card) => {
				card.dataset.previewInit = 'true';
				const canvas = card.querySelector<HTMLCanvasElement>('canvas.title-fx__canvas');
				const textEl = card.querySelector<HTMLElement>('.title-fx__text');
				if (!canvas || !textEl) return;
				const slug = canvas.dataset.slug;
				const codename = canvas.dataset.codename;
				if (!slug || !codename) return;
				// touchTap 'gate': on mobile the first tap plays the effect on the
				// card itself; a second tap follows the link into the experiment.
				mountExperimentPreview(canvas, slug, codename, {
					trigger: card,
					textEl,
					touchTap: 'gate',
				});
			});
	}
	document.addEventListener('astro:page-load', initExperimentPreviews);
	initExperimentPreviews();
</script>
