---
// Shared editorial card for a list of things: blog posts, work, experiments.
// If `href` is given the whole card is a link with a hover affordance; without
// it, it renders as a static article (used for placeholder/undated entries
// that don't yet have a destination to link to).
interface Props {
	href?: string;
	eyebrow: string;
	title: string;
	description: string;
	meta?: string;
	tags?: string[];
	// When true, render an ambient animated background (faint grid + a glowing
	// neon line that traces and fades) behind the card content. See initCardFx.
	ambient?: boolean;
}

const { href, eyebrow, title, description, meta, tags = [], ambient = false } = Astro.props;
const Tag = href ? 'a' : 'div';
---

<Tag
	href={href}
	class:list={[
		'reveal group relative block overflow-hidden rounded-2xl border border-white/10 p-8 transition-colors sm:p-10',
		href && 'hover:border-white/25 hover:bg-white/[0.02]',
	]}
>
	{ambient && <canvas class="card-fx" aria-hidden="true"></canvas>}
	<div class="relative z-10">
		<div class="flex items-start justify-between gap-4">
			<p class="text-eyebrow uppercase text-neutral-500">{eyebrow}</p>
			{meta && <p class="shrink-0 text-small text-neutral-500">{meta}</p>}
		</div>
		<h3 class="mt-5 text-h3 text-neutral-50">{title}</h3>
		<p class="mt-4 max-w-xl text-body text-neutral-400">{description}</p>
		<div class="mt-6 flex flex-wrap items-center justify-between gap-4">
			{
				tags.length > 0 && (
					<ul class="flex flex-wrap gap-x-4 gap-y-1">
						{tags.map((t) => (
							<li class="text-small text-neutral-500">{t}</li>
						))}
					</ul>
				)
			}
			{
				href && (
					<span class="inline-flex items-center gap-2 text-small text-neutral-300 transition-colors group-hover:text-neutral-50">
						Read
						<span aria-hidden="true" class="transition-transform group-hover:translate-x-1">
							&rarr;
						</span>
					</span>
				)
			}
		</div>
	</div>
</Tag>
