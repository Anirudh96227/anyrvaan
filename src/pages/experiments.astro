---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import PageHeader from '../components/PageHeader.astro';
import ExperimentCard from '../components/ExperimentCard.astro';
import Footer from '../components/Footer.astro';
import { experiments } from '../data/experiments';

const sorted = [...experiments].sort((a, b) => a.order - b.order);
---

<Layout
	title="UI Experiments — Anyrvaan"
	description="An internal interaction lab: 24 prototypes exploring motion, physics, perception, and interface design."
>
	<div class="min-h-screen bg-neutral-950 text-neutral-50">
		<Nav />
		<main>
			<PageHeader
				eyebrow="Interaction Lab"
				title="UI Experiments"
				intro="A growing collection of interaction prototypes exploring motion, physics, perception, and interface design. Each experiment begins with a small live preview before unfolding into a fully interactive playground."
				label={`${sorted.length} Active Prototypes`}
				fx
			/>
			<section class="mx-auto max-w-4xl px-6 pb-32">
				<div class="grid gap-6 sm:grid-cols-2">
					{
						sorted.map((e) => (
							<div class="reveal">
								<ExperimentCard
									slug={e.slug}
									order={e.order}
									codename={e.codename}
									classification={e.classification}
									description={e.description}
									tags={e.tags}
								/>
							</div>
						))
					}
				</div>
			</section>
		</main>
		<Footer />
	</div>
</Layout>

<script>
	import { mountExperimentPreview, RENDERERS } from '../scripts/experiment-previews';

	// The page's own title joins the lab: hovering the header block (or tapping
	// it on mobile — each tap re-rolls) runs a randomly sampled sketch from the
	// 24 on the "UI Experiments" text itself.
	function initHeaderFx() {
		const header = document.querySelector<HTMLElement>('[data-fx-header]:not([data-fx-init])');
		if (!header) return;
		header.dataset.fxInit = 'true';
		const canvas = header.querySelector<HTMLCanvasElement>('canvas.title-fx__canvas');
		const textEl = header.querySelector<HTMLElement>('.title-fx__text');
		if (!canvas || !textEl) return;
		const slugs = Object.keys(RENDERERS);
		const pick = () => slugs[(Math.random() * slugs.length) | 0];
		mountExperimentPreview(canvas, pick, textEl.textContent?.trim() ?? 'UI Experiments', {
			trigger: header,
			textEl,
			touchTap: 'retrigger',
		});
	}
	document.addEventListener('astro:page-load', initHeaderFx);
	initHeaderFx();
</script>
