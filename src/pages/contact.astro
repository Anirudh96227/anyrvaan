---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import PageHeader from '../components/PageHeader.astro';
import Footer from '../components/Footer.astro';

// Placeholder contact address — swap for the studio's real inbox when ready.
const email = 'hello@anyrvaan.com';

const elsewhere = ['Instagram', 'LinkedIn', 'GitHub'];
---

<Layout
	title="Contact — Anyrvaan"
	description="Get in touch with Anyrvaan for collaborations, commissions, and conversations."
>
	<div class="min-h-screen bg-neutral-950 text-neutral-50">
		<Nav />
		<main>
			<PageHeader
				eyebrow="Get in Touch"
				title="Contact"
				intro="For collaborations, commissions, and conversations. The door is open — reach out and expect a real reply, not a form-mail loop."
			/>

			<section class="border-t border-white/5 px-6 py-24 sm:py-32">
				<div class="mx-auto max-w-4xl">
					<p class="reveal text-eyebrow uppercase text-neutral-500">Write In</p>
					<a
						href={`mailto:${email}`}
						class="reveal group mt-8 block w-fit text-h1 text-neutral-50 transition-colors hover:text-neutral-300"
					>
						{email}
						<span
							aria-hidden="true"
							class="ml-2 inline-block transition-transform group-hover:translate-x-1 group-hover:-translate-y-1"
							>&nearr;</span
						>
					</a>
					<p class="reveal mt-8 max-w-md text-body text-neutral-500">
						Currently taking on a small number of new projects starting Autumn 2026. Reach out
						earlier to get in the queue.
					</p>
				</div>
			</section>

			<section class="border-t border-white/5 px-6 py-24 sm:py-32">
				<div class="mx-auto max-w-4xl">
					<p class="reveal text-eyebrow uppercase text-neutral-500">Elsewhere</p>
					<ul class="reveal mt-8 flex flex-wrap gap-x-10 gap-y-3">
						{
							elsewhere.map((platform) => (
								<li class="flex items-center gap-2 text-body text-neutral-600">
									{platform}
									<span class="text-small text-neutral-700">— soon</span>
								</li>
							))
						}
					</ul>
				</div>
			</section>
		</main>
		<Footer />
	</div>
</Layout>
