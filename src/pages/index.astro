---
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import ExperimentCard from '../components/ExperimentCard.astro';
import { experiments } from '../data/experiments';

const latestPosts = (await getCollection('blog', ({ data }) => !data.draft))
	.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
	.slice(0, 2);

const formatDate = (d: Date) =>
	new Intl.DateTimeFormat('en-US', { day: 'numeric', month: 'long', year: 'numeric' }).format(d);

// Hand-picked, not first-N: one from each side of the practice — miniature
// art, devotional motion, code-made films, UI history — so the first screen
// of work shows the range instead of one flavor four times. Each carries a
// one-line whisper so a visitor knows what they're looking at without
// clicking through; the case-study summary is too long for a card.
const FEATURED: Record<string, string> = {
	'miniature-india': 'India rebuilt at the scale of a keepsake — thirteen places, hand-lit.',
	'rough-cut-divinity': 'Eight films that stay one breath before the finish.',
	'effects-index': 'Hundreds of small animations, filed into ten short films.',
	'retro-computing': '1982–2007, ten screens redrawn by hand. Not a single screenshot.',
};
const allWork = await getCollection('work', ({ data }) => !data.draft);
const featuredWork = Object.keys(FEATURED)
	.map((id) => allWork.find((p) => p.id === id))
	.filter((p) => p !== undefined);

// Four lab prototypes with visibly different mechanics — afterimage, fluid,
// RGB split, split-flap — each card runs its live hover sketch right here.
const LAB_IDS = ['residual', 'flux-ink', 'spectrum', 'split-flap'];
const labPicks = experiments.filter((e) => LAB_IDS.includes(e.slug));

---

<Layout
	title="Anyrvaan — Films, interfaces, and interaction experiments"
	description="The one-person studio of Anirudh: motion films, interfaces, and interaction experiments, designed and coded by the same pair of hands."
>
	<Nav overlay />
	<!-- Full-page particle field: one continuous world behind every section.
	     Fixed to the viewport, sits above the body background, below all content. -->
	<canvas id="hero-particles" aria-hidden="true"></canvas>
	<main class="relative z-10">
		<!-- Hero: the "stillness" room -->
		<section
			id="hero"
			class="relative flex min-h-screen flex-col items-center justify-center px-6 text-center text-neutral-50"
		>
			<div class="flex flex-col items-center">
				<h1 class="hero-wordmark">Anyrvaan</h1>
				<p class="hero-line hero-line--1 mt-8 text-eyebrow uppercase text-neutral-400">Motion born from stillness</p>
				<p class="hero-line hero-line--2 mt-12 text-body-lg text-neutral-300">
					I design and code things that move — films, interfaces, and interaction experiments.
				</p>
			</div>

			<!-- Scroll cue: a thin line with a light travelling down it, inviting descent.
			     It's a real link that scrolls to the next room. -->
			<a href="#intro" class="scroll-cue" aria-label="Scroll to enter">
				<span class="scroll-cue__line" aria-hidden="true"></span>
			</a>
		</section>

		<!-- Selected Work: four covers, one from each side of the practice. -->
		<section id="work" class="border-t border-white/5 px-6 py-24 sm:py-32">
			<div class="mx-auto max-w-5xl">
				<p class="reveal text-eyebrow uppercase text-neutral-400">Selected Work</p>
				<h2 class="reveal mt-8 max-w-3xl text-h2 text-neutral-100">A few things I've made.</h2>
				<div class="mt-14 grid gap-x-10 gap-y-14 sm:grid-cols-2">
					{
						featuredWork.map((p) => (
							<a href={`/work/${p.id}/`} class="reveal group block">
								<div class="overflow-hidden rounded-2xl border border-white/10 bg-black">
									<Image
										src={p.data.cover!}
										alt={p.data.coverAlt ?? p.data.title}
										widths={[480, 800, 1200]}
										sizes="(max-width: 640px) 100vw, 512px"
										class="aspect-video w-full object-cover transition-transform duration-700 ease-out group-hover:scale-[1.03]"
									/>
								</div>
								<div class="mt-5 flex flex-wrap items-baseline justify-between gap-x-4 gap-y-1">
									<h3 class="text-h3 text-neutral-50">{p.data.title}</h3>
									<p class="text-small text-neutral-400">{p.data.tags[0]} — {p.data.year}</p>
								</div>
								<p class="mt-2 text-small leading-relaxed text-neutral-400">{FEATURED[p.id]}</p>
							</a>
						))
					}
				</div>
				<p class="reveal mt-12">
					<a
						href="/work"
						class="group inline-flex items-center gap-2 text-small text-neutral-300 transition-colors hover:text-neutral-50"
					>
						View all work
						<span aria-hidden="true" class="transition-transform group-hover:translate-x-1">&rarr;</span>
					</a>
				</p>
			</div>
		</section>

		<!-- Interaction Lab: the live prototypes, running right here. -->
		<section id="lab" class="border-t border-white/5 px-6 py-24 sm:py-32">
			<div class="mx-auto max-w-5xl">
				<div class="reveal flex flex-wrap items-baseline justify-between gap-2">
					<p class="text-eyebrow uppercase text-neutral-400">Interaction Lab</p>
					<p class="text-small text-neutral-400">{experiments.length} live prototypes</p>
				</div>
				<h2 class="reveal mt-8 max-w-3xl text-h2 text-neutral-100">
					Typography that folds, melts, and scatters.
				</h2>
				<p class="reveal mt-6 max-w-2xl text-body text-neutral-400">
					Interaction prototypes, each a small system you can push on. Hover a title — the card
					performs its own mechanic.
				</p>
				<div class="mt-14 grid gap-6 sm:grid-cols-2">
					{
						labPicks.map((e) => (
							<div class="reveal">
								<ExperimentCard
									slug={e.slug}
									order={e.order}
									codename={e.codename}
									classification={e.classification}
									description={e.description}
									tags={e.tags}
								/>
							</div>
						))
					}
				</div>
				<p class="reveal mt-12">
					<a
						href="/experiments"
						class="group inline-flex items-center gap-2 text-small text-neutral-300 transition-colors hover:text-neutral-50"
					>
						Enter the lab
						<span aria-hidden="true" class="transition-transform group-hover:translate-x-1">&rarr;</span>
					</a>
				</p>
			</div>
		</section>

		<!-- Journal teaser -->
		<section id="journal" class="border-t border-white/5 px-6 py-24 sm:py-32">
			<div class="mx-auto max-w-5xl">
				<p class="reveal text-eyebrow uppercase text-neutral-400">From the Journal</p>
				<h2 class="reveal mt-8 max-w-3xl text-h2 text-neutral-100">Notes on the practice.</h2>
				<div class="mt-14 flex flex-col gap-10">
					{
						latestPosts.map((post) => (
							<a href={`/blog/${post.id}/`} class="reveal group block">
								<div class="flex flex-wrap items-baseline justify-between gap-2">
									<span class="text-h3 text-neutral-200 transition-colors group-hover:text-neutral-50">
										{post.data.title}
									</span>
									<span class="text-small text-neutral-400">{formatDate(post.data.date)}</span>
								</div>
								<p class="mt-3 max-w-2xl text-body text-neutral-400">{post.data.description}</p>
							</a>
						))
					}
				</div>
				<p class="reveal mt-12">
					<a
						href="/blog"
						class="group inline-flex items-center gap-2 text-small text-neutral-300 transition-colors hover:text-neutral-50"
					>
						Read the journal
						<span aria-hidden="true" class="transition-transform group-hover:translate-x-1">&rarr;</span>
					</a>
				</p>
			</div>
		</section>

		<!-- The studio, last: philosophy after the proof. First person — there
		     is a person here, not a practice describing itself. -->
		<section id="intro" class="border-t border-white/5 px-6 py-24 sm:py-32">
			<div class="mx-auto max-w-5xl">
				<p class="reveal text-eyebrow uppercase text-neutral-400">The Studio</p>
				<h2 class="reveal mt-8 max-w-3xl text-h2 text-neutral-100">
					One person, both halves of the work.
				</h2>
				<p class="reveal mt-8 max-w-2xl text-body-lg text-neutral-400">
					My name's Anirudh. Anyrvaan is the name I make things under — the films, interfaces, and
					experiments above are designed and built by the same pair of hands. Nothing here moves
					without intention.
				</p>
				<p class="reveal mt-12">
					<a
						href="/studio"
						class="group inline-flex items-center gap-2 text-small text-neutral-300 transition-colors hover:text-neutral-50"
					>
						More about the studio
						<span aria-hidden="true" class="transition-transform group-hover:translate-x-1">&rarr;</span>
					</a>
				</p>
			</div>
		</section>
	</main>
	<Footer />
</Layout>

<style>
	/* Decorative canvas: fills the hero, sits behind content (z-0), and is
	   invisible to the pointer so it never blocks the nav or text selection. */
	#hero-particles {
		position: fixed;
		inset: 0;
		display: block;
		width: 100%;
		height: 100%;
		z-index: 0;
		pointer-events: none;
	}

	/* Bespoke hero wordmark — intentionally NOT part of the reusable type scale.
	   Sized in viewport-width units so it feels monumental on every screen and
	   fills most of the width without clipping on phones.
	   Baseline (below) is what reduced-motion users see: a still, bright,
	   perfectly legible wordmark. All motion + light live in the media query. */
	.hero-wordmark {
		font-size: clamp(3rem, 19vw, 16rem);
		line-height: 1;
		letter-spacing: -0.03em;
		/* Descenders (the 'y' tail) hang below the line box; background-clip: text
		   only paints the gradient within the box, so without this the tail gets
		   clipped. The bottom padding extends the paint area under the descenders. */
		padding-bottom: 0.22em;
		font-variation-settings: "wght" 400;
		color: #fafafa; /* neutral-50 */
	}

	/* Subtle "breathing" of the variable weight axis — the surface feels alive. */
	@keyframes wordmark-breathe {
		0%,
		100% {
			font-variation-settings: "wght" 370;
		}
		50% {
			font-variation-settings: "wght" 440;
		}
	}

	/* Raking light — a single bright band travels diagonally across the glyphs,
	   then rests off-screen. Monochrome; light revealing form, not neon.
	   The gradient is clipped to the letter shapes via background-clip: text. */
	@keyframes wordmark-sheen {
		from {
			background-position: 200% center;
		}
		to {
			background-position: -200% center;
		}
	}

	@media (prefers-reduced-motion: no-preference) {
		.hero-wordmark {
			/* Dim base (letters in shadow) + one bright highlight band. */
			background: linear-gradient(
				100deg,
				#a3a3a3 0%,
				#a3a3a3 38%,
				#ffffff 50%,
				#a3a3a3 62%,
				#a3a3a3 100%
			);
			background-size: 200% auto;
			-webkit-background-clip: text;
			background-clip: text;
			-webkit-text-fill-color: transparent;
			color: transparent;
			/* Light sweep (6s, with a rest between passes) + slow breathing (8s). */
			animation:
				wordmark-sheen 6s linear infinite,
				wordmark-breathe 8s ease-in-out infinite;
		}
	}

	/* Hero subtext — each line "arrives" by drawing its letters in from wide
	   tracking to their natural spacing as it brightens, staggered so the
	   second follows the first. Pure CSS, like the wordmark's own sheen: no JS,
	   so there's no flash of visible-then-hidden. Each line settles to its OWN
	   base tracking (eyebrow 0.22em, body-lg 0em), so there's no jump at the
	   end. Baseline (below / reduced motion) is fully visible, still text — the
	   animation only exists inside the no-preference query. As each line lands,
	   the particle field emits one blue shockwave from its center (see
	   initHeroPulse) — text arrives, one ripple, then back to stillness. */
	@keyframes hero-line-settle-1 {
		from {
			opacity: 0;
			letter-spacing: 0.5em;
		}
		to {
			opacity: 1;
			letter-spacing: 0.22em;
		}
	}
	@keyframes hero-line-settle-2 {
		from {
			opacity: 0;
			letter-spacing: 0.2em;
		}
		to {
			opacity: 1;
			letter-spacing: 0em;
		}
	}
	@media (prefers-reduced-motion: no-preference) {
		.hero-line--1 {
			animation: hero-line-settle-1 1.2s cubic-bezier(0.16, 1, 0.3, 1) 0.35s both;
		}
		.hero-line--2 {
			animation: hero-line-settle-2 1.2s cubic-bezier(0.16, 1, 0.3, 1) 0.55s both;
		}
	}

	/* Scroll cue — a faint hairline with a bright capsule dropping down it.
	   Fades out as the visitor scrolls (JS sets opacity), so it never floats
	   awkwardly mid-page. */
	.scroll-cue {
		position: absolute;
		bottom: 2.5rem;
		left: 50%;
		z-index: 10;
		transform: translateX(-50%);
		display: block;
		transition: opacity 0.4s ease;
	}
	.scroll-cue__line {
		display: block;
		position: relative;
		width: 1px;
		height: 48px;
		overflow: hidden;
		background: rgba(255, 255, 255, 0.14);
	}
	.scroll-cue__line::after {
		content: "";
		position: absolute;
		left: -1px;
		top: 0;
		width: 3px;
		height: 10px;
		border-radius: 2px;
		background: #f5f5f5;
		transform: translateY(-16px);
	}
	@media (prefers-reduced-motion: no-preference) {
		.scroll-cue__line::after {
			animation: scroll-cue-drop 2.4s cubic-bezier(0.65, 0, 0.35, 1) infinite;
		}
	}
	@keyframes scroll-cue-drop {
		0% {
			transform: translateY(-16px);
			opacity: 0;
		}
		20% {
			opacity: 1;
		}
		80% {
			opacity: 1;
		}
		100% {
			transform: translateY(48px);
			opacity: 0;
		}
	}
</style>

<script>
	// Cursor-reactive particle field for the hero.
	// Design principle: at rest, ZERO frames render (0% CPU). Motion is born
	// only from the cursor — nearby particles are drawn toward it, then ease home.
	// Honors prefers-reduced-motion and treats touch as a static field.
	function initParticleField(canvas: HTMLCanvasElement) {
		const ctx = canvas.getContext('2d', { alpha: true });
		if (!ctx) return { destroy() {}, emitRipple() {} };
		const reduceMQ = matchMedia('(prefers-reduced-motion: reduce)');
		const coarseMQ = matchMedia('(pointer: coarse)');
		const lowTier = coarseMQ.matches || (navigator.hardwareConcurrency || 8) <= 4;

		const R = 170,
			R2 = R * R,
			MAXPULL = 30,
			EASE = 0.14;
		const IDLE = 900,
			SETTLE = 0.05,
			TAU = Math.PI * 2;
		// The field's one spot of color: a cool blue glow that blooms around
		// particles as the cursor nears them, scaled by the same proximity
		// falloff as the pull itself. Drawn as an explicit radial gradient
		// rather than ctx.shadowBlur — shadow rendering is unreliable across
		// browsers (notably suppressed under Safari/macOS "reduce transparency"
		// and some low-power GPU modes), while a gradient fill always renders.
		const GLOW_RGB = '96, 165, 250',
			GLOW_EXTRA = 20,
			DOT_FILL = 'rgb(235, 235, 235)';

		// Shockwave ripples: a blue ring that expands from a point, brightening
		// (and optionally pushing) the particles its leading edge sweeps over,
		// then dying. Two callers: a hero subtext line landing (glow-only, slow),
		// and a mobile tap (glow + a slight outward push, quicker). Both reuse
		// the same GLOW_RGB blue as the cursor for a consistent look.
		const RIPPLE_LIFE = 1150, // default ms a ripple stays alive
			RIPPLE_SPEED = 0.52, // px/ms the ring expands
			RIPPLE_BAND = 64, // px thickness of the bright leading band
			RIPPLE_STRENGTH = 0.6, // peak glow, kept below the cursor's 0.8
			RIPPLE_PUSH = 22; // px a tap ripple nudges particles outward
		const ripples: { x: number; y: number; start: number; life: number; push: number }[] = [];

		// Shared emit — pushes a ripple in canvas coordinates. Both the public
		// emitRipple (client coords) and the tap handler route through this.
		function emit(cx: number, cy: number, life: number, push: number) {
			ripples.push({ x: cx, y: cy, start: performance.now(), life, push });
			if (ripples.length > 6) ripples.shift(); // safety cap
			wake();
		}

		// Preallocated state — no per-frame allocation.
		let n = 0;
		let px: Float32Array,
			py: Float32Array,
			hx: Float32Array,
			hy: Float32Array,
			rad: Float32Array,
			alpha: Float32Array;
		let vw = 0,
			vh = 0,
			dpr = 1,
			rect = { left: 0, top: 0 } as DOMRect | { left: number; top: number };
		let pointerX = 0,
			pointerY = 0,
			pointerActive = false,
			lastMove = 0;
		let rafId = 0,
			visible = true,
			onScreen = true,
			resizeTimer = 0;

		const canRun = () => visible && onScreen && !reduceMQ.matches;

		function setup() {
			// Robust sizing: never allow a zero-sized canvas (which renders nothing).
			const parent = canvas.parentElement;
			vw = canvas.clientWidth || (parent ? parent.clientWidth : 0) || window.innerWidth;
			vh = canvas.clientHeight || (parent ? parent.clientHeight : 0) || window.innerHeight;
			dpr = Math.min(window.devicePixelRatio || 1, lowTier ? 1 : 1.5);
			canvas.width = Math.max(1, Math.round(vw * dpr)); // NOTE: resets ctx state
			canvas.height = Math.max(1, Math.round(vh * dpr));
			ctx!.setTransform(dpr, 0, 0, dpr, 0, 0); // re-apply after resize
			ctx!.fillStyle = DOT_FILL; // re-apply after resize
			rect = canvas.getBoundingClientRect();
			seed();
		}

		function seed() {
			const area = vw * vh;
			const divisor = 16000 * (lowTier ? 1.5 : 1);
			const target = Math.max(36, Math.min(130, Math.round(area / divisor)));
			px = new Float32Array(target);
			py = new Float32Array(target);
			hx = new Float32Array(target);
			hy = new Float32Array(target);
			rad = new Float32Array(target);
			alpha = new Float32Array(target);
			const cell = Math.sqrt(area / target) || 1;
			const cols = Math.max(1, Math.ceil(vw / cell));
			const rows = Math.max(1, Math.ceil(vh / cell));
			let i = 0;
			for (let r = 0; r < rows && i < target; r++) {
				for (let c = 0; c < cols && i < target; c++) {
					const jx = (Math.random() - 0.5) * 0.7 * cell;
					const jy = (Math.random() - 0.5) * 0.7 * cell;
					const gx = Math.min(vw, Math.max(0, (c + 0.5) * cell + jx));
					const gy = Math.min(vh, Math.max(0, (r + 0.5) * cell + jy));
					hx[i] = px[i] = gx;
					hy[i] = py[i] = gy;
					const rr = Math.random() < 0.7 ? 1.2 + Math.random() * 0.8 : 2.0 + Math.random() * 0.9;
					rad[i] = rr;
					const inv = 1 - (rr - 1.2) / 1.7; // 1 (small) .. 0 (big)
					alpha[i] = 0.28 + inv * 0.42 * (0.85 + Math.random() * 0.15);
					i++;
				}
			}
			n = i;
		}

		function drawStatic() {
			ctx!.clearRect(0, 0, vw, vh);
			for (let i = 0; i < n; i++) {
				ctx!.globalAlpha = alpha[i];
				ctx!.beginPath();
				ctx!.arc((hx[i] + 0.5) | 0, (hy[i] + 0.5) | 0, rad[i], 0, TAU);
				ctx!.fill();
			}
			ctx!.globalAlpha = 1;
		}

		function frame() {
			rafId = 0;
			const now = performance.now();
			if (pointerActive && now - lastMove > IDLE) pointerActive = false;
			const active = pointerActive,
				pxr = pointerX,
				pyr = pointerY;
			// Advance and prune ripples once per frame, before the particle loop.
			for (let r = ripples.length - 1; r >= 0; r--) {
				if (now - ripples[r].start > ripples[r].life) ripples.splice(r, 1);
			}
			const hasRipples = ripples.length > 0;
			let moving = false;
			ctx!.clearRect(0, 0, vw, vh);
			for (let i = 0; i < n; i++) {
				let tx = hx[i],
					ty = hy[i];
				let near = 0; // 0..1 glow strength, from cursor and/or ripples
				if (active) {
					const dx = px[i] - pxr,
						dy = py[i] - pyr;
					const d2 = dx * dx + dy * dy;
					if (d2 < R2) {
						const d = Math.sqrt(d2) || 1e-4; // guard divide-by-zero
						let f = 1 - d / R;
						f *= f; // squared falloff
						near = f;
						const pull = (MAXPULL * f) / d;
						tx = hx[i] - dx * pull; // pull toward pointer
						ty = hy[i] - dy * pull;
					}
				}
				// Ripple influence — the ring's leading band brightens particles
				// (glow) and, for tap ripples, nudges them outward. Measured from
				// the home position; the outward push is added to the ease target
				// so it springs back home naturally as the ripple fades.
				if (hasRipples) {
					for (let r = 0; r < ripples.length; r++) {
						const rp = ripples[r];
						const elapsed = now - rp.start;
						const ringR = elapsed * RIPPLE_SPEED;
						const ddx = hx[i] - rp.x,
							ddy = hy[i] - rp.y;
						const dd = Math.sqrt(ddx * ddx + ddy * ddy);
						const band = 1 - Math.abs(dd - ringR) / RIPPLE_BAND;
						if (band > 0) {
							const fade = 1 - elapsed / rp.life;
							const infl = band * fade * RIPPLE_STRENGTH;
							if (infl > near) near = infl;
							if (rp.push) {
								const p = (band * fade * rp.push) / (dd || 1);
								tx += ddx * p; // push the ease target outward from origin
								ty += ddy * p;
							}
						}
					}
				}
				const nx = px[i] + (tx - px[i]) * EASE;
				const ny = py[i] + (ty - py[i]) * EASE;
				px[i] = nx;
				py[i] = ny;
				if (Math.abs(nx - tx) > SETTLE || Math.abs(ny - ty) > SETTLE) moving = true;
				const cx = (nx + 0.5) | 0,
					cy = (ny + 0.5) | 0;
				if (near > 0.04) {
					// Full-strength glow, independent of this particle's own resting
					// dot alpha — proximity to the cursor is what should drive it.
					const glowR = rad[i] + GLOW_EXTRA * near;
					const glow = ctx!.createRadialGradient(cx, cy, 0, cx, cy, glowR);
					glow.addColorStop(0, `rgba(${GLOW_RGB}, ${(0.8 * near).toFixed(3)})`);
					glow.addColorStop(1, `rgba(${GLOW_RGB}, 0)`);
					ctx!.globalAlpha = 1;
					ctx!.fillStyle = glow;
					ctx!.beginPath();
					ctx!.arc(cx, cy, glowR, 0, TAU);
					ctx!.fill();
					ctx!.fillStyle = DOT_FILL;
				}
				ctx!.globalAlpha = alpha[i];
				ctx!.beginPath();
				ctx!.arc(cx, cy, rad[i], 0, TAU);
				ctx!.fill();
			}
			ctx!.globalAlpha = 1;
			// Keep running while the cursor is active, particles are still easing,
			// or any ripple is alive — otherwise STOP the loop (0 CPU at rest).
			if (active || moving || hasRipples) rafId = requestAnimationFrame(frame);
		}

		function wake() {
			if (!canRun()) return;
			if (!rafId) rafId = requestAnimationFrame(frame); // single-loop guard
		}

		const onMove = (e: PointerEvent) => {
			if (reduceMQ.matches || coarseMQ.matches) return; // no hover on touch
			pointerX = e.clientX - rect.left;
			pointerY = e.clientY - rect.top;
			pointerActive = true;
			lastMove = performance.now();
			wake();
		};
		// Touch has no hovering cursor, so the field's gravity never fires there.
		// Instead a tap sends a quick blue wave that pushes the nearby particles
		// out and settles — the mobile equivalent of the cursor's pull. Taps on
		// links/buttons are left alone so they navigate normally.
		const onTap = (e: PointerEvent) => {
			if (e.pointerType !== 'touch' || !canRun()) return;
			const t = e.target as HTMLElement | null;
			if (t && t.closest('a, button, input, textarea, select, [role="button"]')) return;
			rect = canvas.getBoundingClientRect();
			emit(e.clientX - rect.left, e.clientY - rect.top, 700, RIPPLE_PUSH);
		};
		const onScroll = () => {
			rect = canvas.getBoundingClientRect();
		};
		const onResize = () => {
			clearTimeout(resizeTimer);
			resizeTimer = window.setTimeout(() => {
				setup();
				drawStatic();
			}, 200);
		};
		const onVisibility = () => {
			visible = !document.hidden;
			if (!visible) {
				if (rafId) {
					cancelAnimationFrame(rafId);
					rafId = 0;
				}
			} else if (canRun()) {
				drawStatic();
			}
		};
		const onReduce = () => {
			if (reduceMQ.matches && rafId) {
				cancelAnimationFrame(rafId);
				rafId = 0;
			}
			drawStatic();
		};
		const io =
			'IntersectionObserver' in window
				? new IntersectionObserver(
						(es) => {
							onScreen = es[0].isIntersecting;
							if (!onScreen && rafId) {
								cancelAnimationFrame(rafId);
								rafId = 0;
							}
						},
						{ threshold: 0 }
					)
				: null;

		setup();
		drawStatic(); // always paint the rest state
		// Re-measure once layout has definitely settled (fonts, scrollbars), in
		// case the first measurement ran before the hero had its final size.
		requestAnimationFrame(() => {
			setup();
			drawStatic();
		});
		window.addEventListener('load', onResize);
		window.addEventListener('resize', onResize);
		window.addEventListener('scroll', onScroll, { passive: true });
		document.addEventListener('visibilitychange', onVisibility);
		reduceMQ.addEventListener('change', onReduce);
		// Always attach; onMove/onTap guard internally, so toggling reduce/coarse
		// at runtime is handled correctly.
		window.addEventListener('pointermove', onMove, { passive: true });
		window.addEventListener('pointerdown', onTap, { passive: true });
		if (io) io.observe(canvas);

		return {
			// Fire a glow-only shockwave from a point in client (viewport)
			// coordinates — used by the hero subtext lines as they land. No-ops
			// under reduced motion / off-screen. Re-measures rect in case the
			// page has scrolled.
			emitRipple(clientX: number, clientY: number) {
				if (!canRun()) return;
				rect = canvas.getBoundingClientRect();
				emit(clientX - rect.left, clientY - rect.top, RIPPLE_LIFE, 0);
			},
			destroy() {
				if (rafId) cancelAnimationFrame(rafId);
				clearTimeout(resizeTimer);
				window.removeEventListener('load', onResize);
				window.removeEventListener('resize', onResize);
				window.removeEventListener('scroll', onScroll);
				window.removeEventListener('pointermove', onMove);
				window.removeEventListener('pointerdown', onTap);
				document.removeEventListener('visibilitychange', onVisibility);
				reduceMQ.removeEventListener('change', onReduce);
				if (io) io.disconnect();
			},
		};
	}

	// Fade the scroll cue out as the visitor scrolls away from the top.
	function initScrollCue() {
		const cue = document.querySelector<HTMLElement>('.scroll-cue');
		if (!cue) return;
		const update = () => {
			const o = Math.max(0, 1 - window.scrollY / 280);
			cue.style.opacity = String(o);
			cue.style.pointerEvents = o < 0.05 ? 'none' : '';
		};
		window.addEventListener('scroll', update, { passive: true });
		update();
	}

	// Each hero subtext line, as its letter-spacing settle animation lands,
	// sends one shockwave through the particle field from its own center —
	// text arrives, one ripple, then back to stillness. animationend only
	// fires when the animation runs (no-preference), so this is inherently
	// gated to motion-allowed visitors; emitRipple is a no-op otherwise.
	function initHeroPulse(f: { emitRipple(x: number, y: number): void }) {
		document.querySelectorAll<HTMLElement>('.hero-line:not([data-pulse-init])').forEach((line) => {
			line.dataset.pulseInit = 'true';
			line.addEventListener(
				'animationend',
				() => {
					const r = line.getBoundingClientRect();
					f.emitRipple(r.left + r.width / 2, r.top + r.height / 2);
				},
				{ once: true }
			);
		});
	}

	// Astro lifecycle: works with and without View Transitions. boot() is
	// idempotent (destroys any prior instance), so it's safe to call twice.
	let field: { destroy(): void; emitRipple(x: number, y: number): void } | null = null;
	function boot() {
		const el = document.getElementById('hero-particles') as HTMLCanvasElement | null;
		if (el) {
			if (field) field.destroy();
			field = initParticleField(el);
			initHeroPulse(field);
		}
		initScrollCue();
	}
	document.addEventListener('astro:before-swap', () => {
		if (field) {
			field.destroy();
			field = null;
		}
	});
	document.addEventListener('astro:page-load', boot);
	boot();
</script>
