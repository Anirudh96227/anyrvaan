---
import { Image } from 'astro:assets';
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import PageHeader from '../components/PageHeader.astro';
import Footer from '../components/Footer.astro';
import reelPoster from '../assets/work/reel-poster.jpg';

// The practice, in evidence instead of adjectives — every number is a thing
// on this site you can go watch or push on.
const numbers = [
	{ value: '41', label: 'short films, all rendered from code', href: '/work' },
	{ value: '110', label: 'motion effects, catalogued and cross-indexed', href: '/work/effects-index/' },
	{ value: '24', label: 'live interaction prototypes in the lab', href: '/experiments' },
	{ value: '1', label: 'pair of hands — design and code', href: '/contact' },
];

// Concrete offerings, derived from the case studies rather than aspiration.
const services = [
	{
		title: 'Web & Product Design',
		body: 'Websites and interfaces where the front-end engineering is part of the design — systems, performance, and the small interactions that make a screen feel inhabited. This site is the working sample.',
		tags: ['Web Design', 'Design Systems', 'Front-end Engineering'],
	},
	{
		title: 'Motion & Data Design',
		body: 'Dense or dry information turned legible at a glance — dashboards directed like film scenes, counters with real physics, charts that argue. Built in Remotion and code, not keyframed by hand.',
		tags: ['Motion Design', 'Data Visualization', 'Remotion'],
	},
	{
		title: 'Film & Creative Direction',
		body: 'Short-form film built around one real idea instead of a checklist of trends — devotional pieces, miniature worlds, a dashboard that holds you for a minute without a single word.',
		tags: ['Film', 'Creative Direction', 'Sound'],
	},
];

const principles = [
	'Nothing moves without intention.',
	'Stillness is a decision, not an absence.',
	'Detail is not decoration — it’s evidence of care.',
];
---

<Layout
	title="Studio — Anyrvaan"
	description="The one-person studio of Anirudh — films, interfaces, and tools, designed and coded by the same pair of hands."
>
	<div class="min-h-screen bg-neutral-950 text-neutral-50">
		<Nav />
		<main>
			<PageHeader
				eyebrow="About"
				title="Studio"
				intro="My name's Anirudh. I design and build things that move — Anyrvaan is the name those things ship under. There's no team behind the word: every film, interface, and experiment here was designed and coded by the same pair of hands."
			/>

			<!-- Portfolio reel: a click-to-play facade. The frame stays on-brand
			     (the wordmark over the field) until you press play — only then
			     does the YouTube player load, so its own thumbnail never shows. -->
			<div class="mx-auto max-w-4xl px-6 pb-16">
				<div class="glow-frame reveal rounded-2xl">
					<div class="glow-frame__inner relative aspect-video overflow-hidden border border-white/10 bg-black">
						<button
							type="button"
							class="reel-facade group absolute inset-0 block h-full w-full cursor-pointer text-left"
							data-reel="84ceFWedjds"
							aria-label="Play the studio reel — “Hi, I’m Anirudh”"
						>
							<Image
								src={reelPoster}
								alt="The studio reel — the Anyrvaan wordmark over a starfield"
								class="h-full w-full object-cover opacity-90 transition-opacity duration-500 group-hover:opacity-100"
							/>
							<span aria-hidden="true" class="absolute inset-0 bg-gradient-to-t from-black/60 via-transparent to-transparent"></span>
							<span class="absolute bottom-0 left-0 flex w-full items-center justify-between gap-4 p-5 sm:p-7">
								<span class="flex items-center gap-4">
									<span class="flex h-14 w-14 items-center justify-center rounded-full border border-white/40 bg-black/40 backdrop-blur-sm transition-colors group-hover:border-white group-hover:bg-black/60">
										<svg width="16" height="18" viewBox="0 0 16 18" fill="none" aria-hidden="true">
											<path d="M1 1.5v15l14-7.5-14-7.5z" fill="#fafafa"></path>
										</svg>
									</span>
									<span class="text-body text-neutral-50">Watch the reel — “Hi, I’m Anirudh”</span>
								</span>
								<span class="hidden text-small text-neutral-300 sm:block">2 min</span>
							</span>
						</button>
					</div>
				</div>
			</div>

			<!-- The practice, counted instead of described. Each number links to
			     the place on the site where you can verify it. -->
			<section class="border-t border-white/5 px-6 py-24 sm:py-32">
				<div class="mx-auto max-w-5xl">
					<p class="reveal text-eyebrow uppercase text-neutral-400">The Practice, Counted</p>
					<div class="mt-12 grid gap-x-8 gap-y-12 sm:grid-cols-4">
						{
							numbers.map((n) => (
								<a href={n.href} class="reveal group block">
									<p class="text-h1 tabular-nums text-neutral-50 transition-colors group-hover:text-neutral-200">
										{n.value}
									</p>
									<p class="mt-3 max-w-[16ch] text-small leading-relaxed text-neutral-400 transition-colors group-hover:text-neutral-300">
										{n.label}
									</p>
								</a>
							))
						}
					</div>
				</div>
			</section>

			<!-- Services: concrete offerings, not just philosophy -->
			<section class="border-t border-white/5 px-6 py-24 sm:py-32">
				<div class="mx-auto max-w-5xl">
					<p class="reveal text-eyebrow uppercase text-neutral-400">Services</p>
					<h2 class="reveal mt-8 max-w-3xl text-h2 text-neutral-100">What that looks like, hired.</h2>
					<div class="mt-14 flex flex-col divide-y divide-white/5 border-t border-white/5">
						{
							services.map((s) => (
								<div class="reveal flex flex-col gap-4 py-8 sm:flex-row sm:items-start sm:justify-between sm:gap-12">
									<div class="sm:w-64 sm:shrink-0">
										<h3 class="text-h3 text-neutral-50">{s.title}</h3>
									</div>
									<div class="sm:max-w-xl">
										<p class="text-body text-neutral-400">{s.body}</p>
										<ul class="mt-4 flex flex-wrap gap-x-4 gap-y-1">
											{s.tags.map((t) => (
												<li class="text-small text-neutral-400">{t}</li>
											))}
										</ul>
									</div>
								</div>
							))
						}
					</div>
				</div>
			</section>

			<!-- Principles -->
			<section class="border-t border-white/5 px-6 py-24 sm:py-32">
				<div class="mx-auto max-w-4xl">
					<p class="reveal text-eyebrow uppercase text-neutral-400">Principles</p>
					<ul class="mt-10 flex flex-col gap-6">
						{
							principles.map((line) => (
								<li class="reveal max-w-2xl text-h3 text-neutral-200">{line}</li>
							))
						}
					</ul>
				</div>
			</section>

			<!-- Closing CTA -->
			<section class="border-t border-white/5 px-6 py-24 sm:py-32">
				<div class="reveal mx-auto max-w-4xl">
					<h2 class="max-w-2xl text-h2 text-neutral-100">Have a project in mind?</h2>
					<p class="mt-8">
						<a
							href="/contact"
							class="group inline-flex items-center gap-2 text-small text-neutral-300 transition-colors hover:text-neutral-50"
						>
							Start a conversation
							<span aria-hidden="true" class="transition-transform group-hover:translate-x-1">&rarr;</span>
						</a>
					</p>
				</div>
			</section>
		</main>
		<Footer />
	</div>
</Layout>

<script>
	// Click-to-play: swap the on-brand poster for the real YouTube player only
	// on demand, so the video's own (off-brand) thumbnail never loads.
	function initReel() {
		const btn = document.querySelector<HTMLButtonElement>('.reel-facade:not([data-reel-init])');
		if (!btn) return;
		btn.dataset.reelInit = 'true';
		btn.addEventListener('click', () => {
			const id = btn.dataset.reel;
			if (!id) return;
			const iframe = document.createElement('iframe');
			iframe.className = 'h-full w-full';
			iframe.src = `https://www.youtube-nocookie.com/embed/${id}?rel=0&modestbranding=1&autoplay=1`;
			iframe.title = 'The studio reel';
			iframe.allow = 'accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture';
			iframe.allowFullscreen = true;
			btn.replaceWith(iframe);
		});
	}
	document.addEventListener('astro:page-load', initReel);
	initReel();
</script>
