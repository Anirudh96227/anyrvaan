---
// Full experiment page. The typography is the experiment: the h1 codename is
// replaced by a canvas replica running the exact same per-glyph sketch as the
// card's hover preview (src/scripts/experiment-previews.ts) — here auto-run,
// at display size, reacting to the pointer across the whole stage. The richer
// dedicated playground (parameters, reset, deeper physics) is the deferred
// "Complete Playground" phase — see the project memory.
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import { experiments, type Experiment } from '../../data/experiments';

export async function getStaticPaths() {
	return experiments.map((experiment) => ({
		params: { slug: experiment.slug },
		props: { experiment },
	}));
}

const { experiment } = Astro.props as { experiment: Experiment };
---

<Layout
	title={`${experiment.codename} — Anyrvaan Lab`}
	description={experiment.fullDescription}
	type="article"
>
	<div class="min-h-screen bg-neutral-950 text-neutral-50">
		<Nav />
		<main>
			<section
				class="experiment-stage relative flex min-h-screen flex-col items-center justify-center overflow-hidden px-6 py-32"
				transition:name={`experiment-${experiment.slug}`}
			>
				<div class="relative z-10 mx-auto max-w-2xl text-center">
					<p class="boot-in text-eyebrow uppercase text-neutral-400">{experiment.classification}</p>
					<h1 class="boot-in mt-6 text-h1 text-neutral-50">
						<span class="title-fx">
							<span class="title-fx__text">{experiment.codename}</span>
							<canvas
								class="title-fx__canvas"
								aria-hidden="true"
								data-slug={experiment.slug}
								data-codename={experiment.codename}></canvas>
						</span>
					</h1>
					<p class="boot-in mt-8 text-body-lg text-neutral-300">{experiment.fullDescription}</p>
					{
						experiment.tags.length > 0 && (
							<ul class="boot-in mt-8 flex flex-wrap justify-center gap-x-4 gap-y-1">
								{experiment.tags.map((t) => (
									<li class="text-small text-neutral-500">{t}</li>
								))}
							</ul>
						)
					}
					<p class="boot-in mt-10 text-small text-neutral-600">
						Prototype {String(experiment.order).padStart(2, '0')} of {experiments.length} — the
						title above is running the live sketch from its card, at full size. Move your cursor
						around it. Parameters, reset, and deeper physics are still being built.
					</p>
					<a
						href="/experiments"
						class="boot-in group mt-12 inline-flex items-center gap-2 text-small text-neutral-400 transition-colors hover:text-neutral-50"
					>
						<span aria-hidden="true" class="transition-transform group-hover:-translate-x-1">&larr;</span>
						Back to the Lab
					</a>
				</div>
			</section>
		</main>
		<Footer />
	</div>
</Layout>

<style>
	.experiment-stage {
		isolation: isolate;
	}
	.title-fx {
		position: relative;
		display: inline-block;
	}
	.title-fx__canvas {
		position: absolute;
		pointer-events: none;
	}

	/* Boot sequence — each block of copy draws in with a short stagger, as if
	   the stage were initializing. Baseline (below) is fully visible text. */
	.boot-in {
		opacity: 0;
	}
	@media (prefers-reduced-motion: no-preference) {
		@keyframes boot-in {
			from {
				opacity: 0;
				transform: translateY(10px);
			}
			to {
				opacity: 1;
				transform: translateY(0);
			}
		}
		.boot-in {
			animation: boot-in 0.7s cubic-bezier(0.16, 1, 0.3, 1) both;
		}
		.boot-in:nth-of-type(1) { animation-delay: 0.1s; }
		.boot-in:nth-of-type(2) { animation-delay: 0.2s; }
		.boot-in:nth-of-type(3) { animation-delay: 0.32s; }
		.boot-in:nth-of-type(4) { animation-delay: 0.44s; }
		.boot-in:nth-of-type(5) { animation-delay: 0.56s; }
		.boot-in:nth-of-type(6) { animation-delay: 0.68s; }
	}
	@media (prefers-reduced-motion: reduce) {
		.boot-in {
			opacity: 1;
		}
	}
</style>

<script>
	import { mountExperimentPreview } from '../../scripts/experiment-previews';

	function initStageTitle() {
		const canvas = document.querySelector<HTMLCanvasElement>(
			'.experiment-stage canvas.title-fx__canvas:not([data-preview-init])'
		);
		if (!canvas) return;
		canvas.dataset.previewInit = 'true';
		const textEl = canvas.parentElement?.querySelector<HTMLElement>('.title-fx__text');
		const slug = canvas.dataset.slug;
		const codename = canvas.dataset.codename;
		if (!textEl || !slug || !codename) return;
		const stage = canvas.closest<HTMLElement>('.experiment-stage');
		mountExperimentPreview(canvas, slug, codename, { auto: true, trigger: stage, textEl });
	}
	document.addEventListener('astro:page-load', initStageTitle);
	initStageTitle();
</script>
