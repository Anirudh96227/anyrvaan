---
import { getCollection, getEntry, render } from 'astro:content';
import { Image, getImage } from 'astro:assets';
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import StudiesSection from '../../components/StudiesSection.astro';
import VideoSwitcher from '../../components/VideoSwitcher.astro';
import YouTubeFacade from '../../components/YouTubeFacade.astro';
import WorldBackground, { type World } from '../../components/WorldBackground.tsx';

import ConceptHero, { type ConceptPreset } from '../../components/ConceptHero.tsx';

export async function getStaticPaths() {
	const projects = await getCollection('work', ({ data }) => !data.draft);
	return projects.map((project) => ({
		params: { slug: project.id },
		props: { project },
	}));
}

const { project } = Astro.props;
const { Content } = await render(project);

const PRESETS: Record<string, ConceptPreset> = {
	'retro-computing': 'retro',
	'ui-replicas': 'ui-replicas',
	'dashboard-cinema': 'dashboard',
	'effects-index': 'effects',
	'spiritual-series': 'spiritual',
	'anti-ui-atlas': 'anti-ui',
};
const conceptPreset = PRESETS[project.id];

// A project's or study's `video` can be a local file (starts with "/") or a
// YouTube URL — extract the video ID so we know which player to render.
function getYouTubeId(url: string): string | null {
	const match = url.match(
		/(?:youtube\.com\/(?:watch\?v=|embed\/|shorts\/)|youtu\.be\/)([a-zA-Z0-9_-]{11})/
	);
	return match ? match[1] : null;
}
const youtubeId = project.data.video ? getYouTubeId(project.data.video) : null;

// A "hub" case study gathers several other work entries (kept as drafts, so
// they don't appear as separate cards or pages) into one page — each rendered
// in order as its own collection: a lead reel, its prose, then its studies grid.
const memberSlugs = project.data.collections ?? [];
const isHub = memberSlugs.length > 0;

// A facade-video case study (hero film + library variants, poster-first).
const facade = project.data.facade;
const members = await Promise.all(
	memberSlugs.map(async (slug) => {
		const entry = await getEntry('work', slug);
		if (!entry) throw new Error(`collections: work entry "${slug}" not found`);
		// Each collection's individual films become the switcher's chapters —
		// one button per film, all sharing a single player.
		const chapters = (
			await getCollection('studies', (s) => s.data.project === slug && !s.data.draft)
		)
			.sort((a, b) => a.data.number - b.data.number)
			.map((s) => ({
				id: s.data.video ? getYouTubeId(s.data.video) : null,
				number: s.data.number,
				title: s.data.title,
				thread: s.data.thread ?? null,
			}))
			.filter((c): c is { id: string; number: number; title: string; thread: string | null } =>
				Boolean(c.id)
			);
		return {
			slug,
			entry,
			Content: (await render(entry)).Content,
			reelId: entry.data.video ? getYouTubeId(entry.data.video) : null,
			chapters,
		};
	})
);

// An image-plate project's gallery renders as a sequential, alternating
// image/text sequence (same rhythm as a video-studies project), with its
// last plate (the "finale" — e.g. a group shot) shown wide beneath it,
// matching how this content is actually authored: N individual pieces, then
// one that brings them together. A plate's caption is authored as
// "House — Character"; split it so the house name can lead as an eyebrow.
const gallery = project.data.gallery ?? [];
const galleryPlates = gallery.length > 1 ? gallery.slice(0, -1) : gallery;
const galleryFinale = gallery.length > 1 ? gallery[gallery.length - 1] : null;
const platesWithCaption = galleryPlates.map((img) => {
	const [eyebrow, name] = (img.caption ?? '').split('—').map((s) => s.trim());
	return { img, eyebrow: eyebrow || null, name: name || img.caption || '' };
});

const frames = project.data.frames ?? [];

// Share preview: use the case study's own cover so a shared work link previews
// with its still, not the site-wide default. JPEG for the widest scraper support.
const ogImage = project.data.cover
	? (await getImage({ src: project.data.cover, width: 1200, format: 'jpeg' })).src
	: undefined;

// An ambient "world" behind the five filmed case studies, matched to subject.
// Other case studies (the AI-image ones) keep the plain dark ground.
const WORLDS: Record<string, World> = {
	'effects-index': 'effects',
	'spiritual-series': 'spiritual',
	'retro-computing': 'retro',
	'ui-replicas': 'ui',
};
const world = WORLDS[project.id];
---

<Layout
	title={`${project.data.title} — Anyrvaan Work`}
	description={project.data.summary}
	image={ogImage}
	type="article"
>
	<div class:list={['relative min-h-screen text-neutral-50', !world && 'bg-neutral-950']}>
		{world && <WorldBackground client:visible theme={world} />}
		<div class="relative z-10">
			<Nav />
			<main>
			<header class="mx-auto max-w-4xl px-6 pt-40 pb-16">
				<p class="reveal text-eyebrow uppercase text-neutral-400">Case Study — {project.data.year}</p>
				<h1 class="post-title reveal mt-6 text-h1 text-neutral-50">{project.data.title}</h1>
				<p class="reveal mt-8 max-w-2xl text-body-lg text-neutral-300">{project.data.summary}</p>
				{
					project.data.tags.length > 0 && (
						<ul class="reveal mt-8 flex flex-wrap gap-x-4 gap-y-1">
							{project.data.tags.map((t) => (
								<li class="text-small text-neutral-400 transition-colors hover:text-neutral-200" data-bloom>
									{t}
								</li>
							))}
						</ul>
					)
				}
			</header>

			{
				project.data.thesis && (
					<div class="mx-auto max-w-4xl px-6 pb-20">
						<p class="thesis-sweep reveal max-w-3xl text-h2 text-neutral-50">{project.data.thesis}</p>
					</div>
				)
			}

			{
				project.data.behanceId && (
					<div class="mx-auto max-w-4xl px-6 pb-16">
						<div class="glow-frame reveal rounded-2xl">
							<div class="glow-frame__inner aspect-[404/316] border border-white/10 bg-black">
								<iframe
									class="h-full w-full"
									src={`https://www.behance.net/embed/project/${project.data.behanceId}?ilo0=1`}
									title={project.data.title}
									loading="lazy"
									allow="clipboard-write"
									allowfullscreen
									referrerpolicy="strict-origin-when-cross-origin"
								/>
							</div>
						</div>
					</div>
				)
			}

			{
				conceptPreset ? (
					<ConceptHero client:visible preset={conceptPreset} title={project.data.title} />
				) : facade ? (
					<div class="mx-auto max-w-4xl px-6 pb-16">
						<figure class="reveal">
							<YouTubeFacade
								youtube={facade.hero.youtube}
								poster={facade.hero.poster}
								posterAlt={facade.hero.posterAlt}
								title={project.data.title}
								loading="eager"
							/>
							{facade.hero.caption && (
								<figcaption class="mt-4 text-small text-neutral-400">{facade.hero.caption}</figcaption>
							)}
						</figure>
					</div>
				) : (
					project.data.video && (
						<div class="mx-auto max-w-4xl px-6 pb-16">
							<div class="hero-video glow-frame reveal rounded-2xl">
								<div class="glow-frame__inner aspect-video border border-white/10 bg-black">
									{youtubeId ? (
										<iframe
											class="h-full w-full"
											src={`https://www.youtube-nocookie.com/embed/${youtubeId}?rel=0&modestbranding=1`}
											data-autoplay-src={`https://www.youtube-nocookie.com/embed/${youtubeId}?rel=0&modestbranding=1&autoplay=1&mute=1`}
											title={project.data.title}
											allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
											allowfullscreen
										/>
									) : (
										<video
											class="h-full w-full"
											src={project.data.video}
											poster={project.data.poster}
											controls
											playsinline
											preload="metadata"
										/>
									)}
								</div>
							</div>
						</div>
					)
				)
			}

			<article class="mx-auto max-w-3xl border-t border-white/5 px-6 py-16">
				<div class="prose">
					<Content />
				</div>
			</article>

			{
				facade && facade.libraries.length > 0 && (
					<section class="border-t border-white/5 px-6 py-24 sm:py-32">
						<div class="mx-auto max-w-5xl">
							<p class="reveal text-eyebrow uppercase text-neutral-400">
								{facade.librariesEyebrow ?? 'The Library'}
							</p>
							<h2 class="reveal mt-8 max-w-3xl text-h2 text-neutral-100">
								{facade.librariesHeading ?? 'Same pipeline, rebuilt.'}
							</h2>
							{facade.librariesIntro && (
								<p class="reveal mt-6 max-w-2xl text-body text-neutral-400">{facade.librariesIntro}</p>
							)}
							<div class="mt-16 grid gap-10 sm:gap-12 md:grid-cols-2">
								{facade.libraries.map((lib) => (
									<figure class="reveal">
										<YouTubeFacade
											youtube={lib.youtube}
											poster={lib.poster}
											posterAlt={lib.posterAlt}
											title={lib.label ?? project.data.title}
										/>
										{lib.caption && (
											<figcaption class="mt-4 text-small text-neutral-400">{lib.caption}</figcaption>
										)}
									</figure>
								))}
							</div>
						</div>
					</section>
				)
			}

			{
				gallery.length > 0 && (
					<div class="mx-auto max-w-5xl px-6 pb-16">
						<div class="flex flex-col gap-20 sm:gap-28">
							{platesWithCaption.map(({ img, eyebrow, name }, i) => (
								<article class="reveal grid items-center gap-8 sm:grid-cols-2 sm:gap-12">
									<div
										class:list={['mx-auto w-full max-w-xs sm:mx-0', i % 2 === 1 && 'sm:order-2']}
									>
										<figure class="glow-frame rounded-2xl">
											<div class="glow-frame__inner relative aspect-square border border-white/10 bg-black">
												<span class="pointer-events-none absolute left-3 top-3 z-10 text-eyebrow text-neutral-400/80">
													{String(i + 1).padStart(2, '0')}
												</span>
												<Image src={img.src} alt={img.alt} loading="lazy" class="h-full w-full object-cover" />
											</div>
										</figure>
									</div>
									<div class:list={['mx-auto w-full max-w-md sm:mx-0', i % 2 === 1 && 'sm:order-1']}>
										{eyebrow && <p class="text-eyebrow uppercase text-neutral-400">{eyebrow}</p>}
										<h2 class="mt-4 text-h3 text-neutral-50">{name}</h2>
										{img.note && <p class="mt-6 text-body text-neutral-400">{img.note}</p>}
									</div>
								</article>
							))}
						</div>
						{galleryFinale && (
							<figure class="glow-frame reveal mt-20 rounded-2xl sm:mt-28">
								<div class="glow-frame__inner border border-white/10 bg-black">
									<Image src={galleryFinale.src} alt={galleryFinale.alt} loading="lazy" class="w-full object-cover" />
									{galleryFinale.caption && (
										<figcaption class="px-4 py-3 text-small text-neutral-400">{galleryFinale.caption}</figcaption>
									)}
								</div>
							</figure>
						)}
					</div>
				)
			}

			{
				isHub ? (
					members.map(({ slug, entry, Content: MemberContent, reelId, chapters }, i) => (
						<section id={slug} class="scroll-mt-24 border-t border-white/5 px-6 py-20 sm:py-28">
							<div class="mx-auto max-w-5xl">
								<p class="reveal text-eyebrow uppercase text-neutral-400">
									Collection {String(i + 1).padStart(2, '0')} — {entry.data.title}
								</p>
								<h2 class="reveal mt-4 text-h2 text-neutral-50">{entry.data.title}</h2>
								<p class="reveal mt-6 max-w-2xl text-body-lg text-neutral-300">{entry.data.summary}</p>
								{entry.data.thesis && (
									<p class="thesis-sweep reveal mt-8 max-w-3xl text-h3 text-neutral-100">{entry.data.thesis}</p>
								)}
								<VideoSwitcher title={entry.data.title} reel={reelId} chapters={chapters} />
								<div class="prose mt-12 max-w-3xl">
									<MemberContent />
								</div>
							</div>
						</section>
					))
				) : (
					<StudiesSection
						projectId={project.id}
						title={project.data.title}
						eyebrow={project.data.studiesEyebrow}
						heading={project.data.studiesHeading}
						intro={project.data.studiesIntro}
					/>
				)
			}

			<footer class="mx-auto max-w-3xl px-6 pb-32">
				<a
					href="/work"
					class="group inline-flex items-center gap-2 text-small text-neutral-400 transition-colors hover:text-neutral-50"
				>
					<span aria-hidden="true" class="transition-transform group-hover:-translate-x-1">&larr;</span>
					Back to Work
				</a>
			</footer>
		</main>
		<Footer />
		</div>
	</div>
</Layout>

<script>
	// A single-video case study's hero plays once, muted, the first time it
	// scrolls into view — then it's entirely under the visitor's own control
	// via native controls (unmute, pause, seek). It never auto-pauses or
	// auto-resumes after that first trigger, so it can't fight a visitor who's
	// deliberately paused it and scrolled past to keep reading.
	function initHeroVideo() {
		const wrap = document.querySelector<HTMLElement>('.hero-video:not([data-hero-init])');
		if (!wrap) return;
		wrap.dataset.heroInit = 'true';
		if (matchMedia('(prefers-reduced-motion: reduce)').matches || !('IntersectionObserver' in window)) {
			return;
		}
		const io = new IntersectionObserver(
			(entries, obs) => {
				if (!entries[0].isIntersecting) return;
				const video = wrap.querySelector<HTMLVideoElement>('video');
				const iframe = wrap.querySelector<HTMLIFrameElement>('iframe');
				if (video) {
					video.muted = true;
					video.play().catch(() => {});
				} else if (iframe?.dataset.autoplaySrc) {
					iframe.src = iframe.dataset.autoplaySrc;
				}
				obs.disconnect();
			},
			{ threshold: 0.5 }
		);
		io.observe(wrap);
	}
	document.addEventListener('astro:page-load', initHeroVideo);
	initHeroVideo();

	// Video switcher: one player per collection, a button per film. Clicking a
	// tab swaps the single stage iframe (autoplaying, since it's a user gesture)
	// and updates the caption — so all the films are one click apart without a
	// page full of separate players.
	function initVideoSwitchers() {
		document
			.querySelectorAll<HTMLElement>('[data-video-switcher]:not([data-vs-init])')
			.forEach((sw) => {
				sw.dataset.vsInit = 'true';
				const stage = sw.querySelector<HTMLIFrameElement>('.video-switcher__stage');
				const capTitle = sw.querySelector<HTMLElement>('.video-switcher__caption-title');
				const capSub = sw.querySelector<HTMLElement>('.video-switcher__caption-sub');
				const tabs = sw.querySelectorAll<HTMLButtonElement>('.video-switcher__tab');
				if (!stage) return;
				tabs.forEach((tab) => {
					tab.addEventListener('click', () => {
						const id = tab.dataset.videoId;
						if (!id) return;
						tabs.forEach((t) => t.setAttribute('aria-selected', 'false'));
						tab.setAttribute('aria-selected', 'true');
						stage.src = `https://www.youtube-nocookie.com/embed/${id}?rel=0&modestbranding=1&autoplay=1`;
						const label = tab.dataset.videoLabel ?? '';
						const sub = tab.dataset.videoSub ?? '';
						if (capTitle) capTitle.textContent = label;
						if (capSub) capSub.textContent = sub ? ` — ${sub}` : '';
					});
				});
			});
	}
	document.addEventListener('astro:page-load', initVideoSwitchers);
	initVideoSwitchers();

	// Each study's reel is a real embed, sitting inline in the page — no
	// lightbox. Its iframe only gets a `src` once it scrolls near view (via
	// data-lazy-src), so a page of embeds doesn't load them all at once.
	// Loads go through a small queue (2 at a time, next starts when one
	// finishes or times out) because Behance rate-limits a burst of
	// simultaneous embed requests from one client and returns errors —
	// a fast scroll past a dozen tiles must not fire a dozen requests at once.
	function initStudyReels() {
		const frames = document.querySelectorAll<HTMLIFrameElement>(
			'.study-reel iframe[data-lazy-src]:not([data-lazy-init])'
		);
		if (!frames.length) return;
		frames.forEach((f) => (f.dataset.lazyInit = 'true'));

		const pending: HTMLIFrameElement[] = [];
		let active = 0;
		const MAX_CONCURRENT = 2;
		function pump() {
			while (active < MAX_CONCURRENT && pending.length) {
				const f = pending.shift()!;
				// getAttribute, not .src — the property resolves an empty src=""
				// against the page URL and comes back truthy for every frame.
				if (!f.dataset.lazySrc || f.getAttribute('src')) continue;
				active++;
				let settled = false;
				const done = () => {
					if (settled) return;
					settled = true;
					active--;
					pump();
				};
				f.addEventListener('load', done, { once: true });
				f.addEventListener('error', done, { once: true });
				setTimeout(done, 8000); // never let one stuck embed stall the queue
				f.src = f.dataset.lazySrc;
			}
		}
		const enqueue = (f: HTMLIFrameElement) => {
			pending.push(f);
			pump();
		};

		if (!('IntersectionObserver' in window)) {
			frames.forEach(enqueue);
			return;
		}
		const io = new IntersectionObserver(
			(entries, obs) => {
				for (const entry of entries) {
					if (!entry.isIntersecting) continue;
					const f = entry.target as HTMLIFrameElement;
					enqueue(f);
					obs.unobserve(f);
				}
			},
			{ rootMargin: '400px 0px' }
		);
		frames.forEach((f) => io.observe(f));
	}
	document.addEventListener('astro:page-load', initStudyReels);
	initStudyReels();

	// Flip cards: "Flip the frame" (or the card itself) toggles .is-flipped,
	// which the CSS 3D transform in global.css turns into a Y-axis rotation
	// between the video and its companion illustration. Pausing the video's
	// iframe when flipped away isn't necessary — YouTube keeps playing behind
	// the rotated face, same as it would off-screen.
	function initFlipCards() {
		const toggles = document.querySelectorAll<HTMLButtonElement>(
			'.flip-card__toggle:not([data-flip-init])'
		);
		toggles.forEach((toggle) => {
			toggle.dataset.flipInit = 'true';
			const card = toggle.closest('div')?.querySelector<HTMLElement>('.flip-card');
			if (!card) return;
			toggle.setAttribute('aria-pressed', 'false');
			toggle.addEventListener('click', () => {
				const flipped = card.classList.toggle('is-flipped');
				toggle.setAttribute('aria-pressed', String(flipped));
			});
		});
	}
	document.addEventListener('astro:page-load', initFlipCards);
	initFlipCards();

	// Tool-chain accordion: one step's detail open at a time per study, so a
	// visitor scans steps rather than reading four paragraphs at once.
	function initToolChain() {
		const lists = document.querySelectorAll<HTMLElement>(
			'.tool-chain__list:not([data-chain-init])'
		);
		lists.forEach((list) => {
			list.dataset.chainInit = 'true';
			const triggers = list.querySelectorAll<HTMLButtonElement>('.tool-chain__trigger');
			triggers.forEach((trigger) => {
				trigger.addEventListener('click', () => {
					const expanded = trigger.getAttribute('aria-expanded') === 'true';
					triggers.forEach((t) => t.setAttribute('aria-expanded', 'false'));
					trigger.setAttribute('aria-expanded', String(!expanded));
				});
			});
		});
	}
	document.addEventListener('astro:page-load', initToolChain);
	initToolChain();

	function initYoutubeFacades() {
		document.querySelectorAll<HTMLElement>('.study-youtube-facade:not([data-facade-init])').forEach((facade) => {
			facade.dataset.facadeInit = 'true';
			facade.addEventListener('click', () => {
				const youtubeId = facade.getAttribute('data-youtube-id');
				const title = facade.getAttribute('data-title') || '';
				if (!youtubeId) return;

				const iframe = document.createElement('iframe');
				iframe.className = 'h-full w-full';
				iframe.src = `https://www.youtube-nocookie.com/embed/${youtubeId}?rel=0&modestbranding=1&autoplay=1`;
				iframe.title = title;
				iframe.allow = 'accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture';
				iframe.allowFullscreen = true;

				facade.replaceWith(iframe);
			});
		});
	}
	document.addEventListener('astro:page-load', initYoutubeFacades);
	initYoutubeFacades();
</script>
