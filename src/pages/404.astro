---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Page Not Found — Anyrvaan" description="This page doesn't exist.">
	<div class="min-h-screen bg-neutral-950 text-neutral-50">
		<Nav />
		<main>
			<div class="mx-auto flex min-h-[70vh] max-w-4xl flex-col justify-center px-6 py-32">
				<!-- The "404" scatters into debris and reassembles — the one page
				     every visitor forgives being strange on. Click it to re-scatter.
				     Reduced motion / no-JS: it just sits there, plainly. -->
				<button
					type="button"
					class="notfound-fx w-fit cursor-pointer text-left"
					aria-label="Scatter and reassemble"
					data-notfound
				>
					<span class="title-fx relative inline-block">
						<span
							class="title-fx__text block text-[clamp(6rem,22vw,15rem)] font-semibold leading-none tracking-tight text-neutral-50"
							>404</span
						>
						<canvas class="title-fx__canvas pointer-events-none absolute" aria-hidden="true"></canvas>
					</span>
				</button>
				<h1 class="reveal mt-8 text-h2 text-neutral-100">Nothing here.</h1>
				<p class="reveal mt-6 max-w-xl text-body-lg text-neutral-400">
					Not every room in this site is built yet — and this particular one was never here to begin
					with. The link that brought you here is either old or wrong.
				</p>
				<p class="reveal mt-12">
					<a
						href="/"
						class="group inline-flex items-center gap-2 text-small text-neutral-300 transition-colors hover:text-neutral-50"
					>
						<span aria-hidden="true" class="transition-transform group-hover:-translate-x-1">&larr;</span>
						Back to the studio
					</a>
				</p>
			</div>
		</main>
		<Footer />
	</div>
</Layout>

<style>
	.title-fx {
		position: relative;
		display: inline-block;
	}
	.title-fx__canvas {
		position: absolute;
	}
	.notfound-fx {
		background: none;
		border: 0;
		padding: 0;
	}
</style>

<script>
	import { mountExperimentPreview } from '../scripts/experiment-previews';

	// The "404" runs the Swarm sketch — scatter into debris, reassemble, break
	// apart again — and re-triggers on click/tap. mountExperimentPreview no-ops
	// under reduced motion, leaving the static numerals as the baseline.
	function init404() {
		const host = document.querySelector<HTMLElement>('[data-notfound]:not([data-fx-init])');
		if (!host) return;
		host.dataset.fxInit = 'true';
		const canvas = host.querySelector<HTMLCanvasElement>('canvas.title-fx__canvas');
		const textEl = host.querySelector<HTMLElement>('.title-fx__text');
		if (!canvas || !textEl) return;
		mountExperimentPreview(canvas, 'swarm', '404', {
			auto: true,
			trigger: host,
			textEl,
			touchTap: 'retrigger',
		});
	}
	document.addEventListener('astro:page-load', init404);
	init404();
</script>
